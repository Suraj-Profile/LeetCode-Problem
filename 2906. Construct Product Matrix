from typing import List

class Solution:
    def constructProductMatrix(self, grid: List[List[int]]) -> List[List[int]]:
        MOD = 12345
        
        n, m = len(grid), len(grid[0])
        
        # Flatten the grid
        arr = []
        for row in grid:
            arr.extend(row)
        
        k = len(arr)
        
        # Prefix product stored directly in result
        res = [1] * k
        for i in range(1, k):
            res[i] = (res[i - 1] * arr[i - 1]) % MOD
        
        # Suffix product using single variable
        suffix = 1
        for i in range(k - 1, -1, -1):
            res[i] = (res[i] * suffix) % MOD
            suffix = (suffix * arr[i]) % MOD
        
        # Convert back to 2D matrix
        ans = []
        idx = 0
        for i in range(n):
            row = []
            for j in range(m):
                row.append(res[idx])
                idx += 1
            ans.append(row)
        
        return ans
