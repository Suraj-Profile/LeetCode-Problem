from typing import List

class Robot:

    def __init__(self, width: int, height: int):
        self.w = width
        self.h = height
        self.x = 0
        self.y = 0
        self.dir = 0  # 0=East, 1=North, 2=West, 3=South
        
        self.directions = [(1,0), (0,1), (-1,0), (0,-1)]
        self.dir_names = ["East", "North", "West", "South"]
        
        self.cycle = 2 * (width + height) - 4

    def step(self, num: int) -> None:
        num %= self.cycle
        
        # Special edge case
        if num == 0 and self.x == 0 and self.y == 0:
            self.dir = 3  # South
            return
        
        while num > 0:
            dx, dy = self.directions[self.dir]
            nx, ny = self.x + dx, self.y + dy
            
            # If out of bounds → turn
            if nx < 0 or nx >= self.w or ny < 0 or ny >= self.h:
                self.dir = (self.dir + 1) % 4
            else:
                self.x, self.y = nx, ny
                num -= 1

    def getPos(self) -> List[int]:
        return [self.x, self.y]

    def getDir(self) -> str:
        return self.dir_names[self.dir]
