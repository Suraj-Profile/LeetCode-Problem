class Solution:
    def rotatedDigits(self, n: int) -> int:
        c = 0
        
        for i in range(1, n + 1):
            s = str(i)
            good = False
            valid = True
            
            for ch in s:
                if ch in '347':
                    valid = False
                    break
                if ch in '2569':
                    good = True
            
            if valid and good:
                c += 1
        
        return c
